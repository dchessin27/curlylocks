# Curly Locks — API Keys
# Copy to .env and fill in your keys

# The Odds API — free tier at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Anthropic Claude — https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# Port (optional, default 3747)
# PORT=3747

# Optional — Telegram alerts ~10 min before each pick's game starts
# Create a bot via @BotFather on Telegram to get a token, then message
# the bot and check https://api.telegram.org/bot<TOKEN>/getUpdates for your chat id
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# Optional — where the day's picks are cached on disk so they survive
# restarts. On Railway, add a Volume mounted at /data and set this to
# /data so picks also survive redeploys. Defaults to ./server/data.
# DATA_DIR=/data
